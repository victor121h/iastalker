modules = ["nodejs-20", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
integrations = ["resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Next.js Dev Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Email Cron"

[[workflows.workflow]]
name = "Next.js Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Email Cron"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/email-cron.js"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "node scripts/email-cron.js & npm run start"]
build = ["npm", "run", "build"]

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[userenv]

[userenv.shared]
PERFECTPAY_WEBHOOK_TOKEN = "f71e05f3f70c465c7c01fb8ce2b327b7"
ADMIN_MONITOR_PASSWORD = "admin2024obs"
